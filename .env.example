# Kryfto Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── API ──────────────────────────────────────────
KRYFTO_PORT=8080
KRYFTO_LOG_LEVEL=info
KRYFTO_API_TOKEN=CHANGE_ME
KRYFTO_BOOTSTRAP_ADMIN_TOKEN=CHANGE_ME
KRYFTO_PROJECT_ID=dev
KRYFTO_JOB_MAX_ATTEMPTS=3
KRYFTO_RATE_LIMIT_RPM=120

# ── Security ─────────────────────────────────────
KRYFTO_SSRF_BLOCK_PRIVATE_RANGES=true
KRYFTO_ALLOWED_HOSTS=

# ── Postgres ─────────────────────────────────────
POSTGRES_DB=kryfto
POSTGRES_USER=kryfto
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PG_POOL_MAX=20

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Artifacts ────────────────────────────────────
KRYFTO_ARTIFACT_BACKEND=local
KRYFTO_LOCAL_ARTIFACT_DIR=./data/artifacts
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=kryfto-artifacts
S3_FORCE_PATH_STYLE=true

# ── Stealth / Proxy (Optional) ───────────────────
# KRYFTO_STEALTH_MODE=true
# KRYFTO_ROTATE_USER_AGENT=true
# KRYFTO_PROXY_URLS=socks5://proxy1:1080,http://user:pass@proxy2:8080

# ── Optional Paths ───────────────────────────────
KRYFTO_RECIPES_DIR=
KRYFTO_MIGRATIONS_DIR=

# ── CLI / MCP Client Defaults ────────────────────
API_BASE_URL=http://localhost:8080
API_TOKEN=CHANGE_ME
