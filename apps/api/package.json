{
  "name": "@kryfto/api",
  "version": "3.6.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch dist/index.js",
    "build": "tsup src/index.ts src/migrate.ts src/seed-admin.ts --format esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "echo 'e2e is run from root'",
    "lint": "echo 'lint: configure eslint'",
    "migrate": "node dist/migrate.js",
    "seed:admin": "node dist/seed-admin.js"
  },
  "dependencies": {
    "@kryfto/shared": "workspace:*",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@opentelemetry/api": "^1.9.0",
    "bullmq": "^5.24.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
