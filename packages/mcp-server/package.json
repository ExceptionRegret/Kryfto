    "playwright": "^1.49.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
