{
  "name": "@kryfto/mcp-server",
  "version": "3.7.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kryfto-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
