{
  "name": "@kryfto/sdk-ts",
  "version": "3.8.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint: configure eslint'"
  },
  "dependencies": {
    "@kryfto/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
